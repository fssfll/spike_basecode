{
  "terminal.integrated.profiles.osx": {
    "venv (zsh)": {
      "path": "zsh",
      "args": ["-l", "-c", "source .venv/bin/activate && exec zsh -l"]
    }
  },
  "terminal.integrated.defaultProfile.osx": "venv (zsh)",

  "terminal.integrated.profiles.windows": {
    "venv (PowerShell)": {
      "path": "powershell.exe",
      "args": ["-NoExit", "-ExecutionPolicy", "Bypass", "-Command", ".\\.venv\\Scripts\\Activate.ps1"]
    }
  },
  "terminal.integrated.defaultProfile.windows": "venv (PowerShell)",

  "terminal.integrated.profiles.linux": {
    "venv (bash)": {
      "path": "bash",
      "args": ["-lc", "source .venv/bin/activate && exec bash -l"]
    }
  },
  "terminal.integrated.defaultProfile.linux": "venv (bash)"
}

