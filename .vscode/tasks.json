{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Activate venv",
      "type": "shell",

      "command": "bash",
      "args": ["-lc", "source .venv/bin/activate && exec $SHELL -l"],

      "windows": {
        "command": "powershell",
        "args": [
          "-NoExit",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          ".\\.venv\\Scripts\\Activate.ps1"
        ]
      },

      "osx": {
        "command": "zsh",
        "args": ["-lc", "source .venv/bin/activate && exec zsh -l"]
      },

      "linux": {
        "command": "bash",
        "args": ["-lc", "source .venv/bin/activate && exec bash -l"]
      },

      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}

